# Telegram Bot Token
TELEGRAM_BOT_TOKEN="8901004949:AAH5tDlxyLahIr7vh9iRLC00bDwV4UOIj9k"

# GitHub Personal Access Token (PAT) or Token
GITHUB_PAT="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"

# GitHub Repository in format: username/repo-name (e.g., 2507779/dacar16)
GITHUB_REPO="2507779/dacar16"

# GitHub Branch (default is "main")
GITHUB_BRANCH="main"

# Allowed Telegram Chat IDs (comma-separated or space-separated)
